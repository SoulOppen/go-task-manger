DB_DRIVER=mysql
DB_HOST=localhost
DB_PORT=3306
DB_USER=tu_usuario
DB_PASSWORD=tu_password
DB_NAME=tu_base_de_datos

# Comando `gtm task add-prompt` (LLM): sin valores por defecto en el binario.
# Obligatorios: API key, proveedor y modelo (en .env o mediante --llm-provider / --llm-model).
# GTM_LLM_API_KEY=
# GTM_LLM_PROVIDER=gemini
# GTM_LLM_MODEL=gemini-2.0-flash
# Opcional: GTM_LLM_BASE_URL (p. ej. endpoint compatible OpenAI si no usas el host por defecto del driver)
